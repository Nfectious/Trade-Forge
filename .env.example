# =============================================================================
# TRADEFORGE - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy to .env.production and fill in all values before starting.
#
#   cp .env.example .env.production
#
# Lines marked REQUIRED must be set. Lines marked OPTIONAL can be left blank.
# =============================================================================


# =============================================================================
# DATABASE (PostgreSQL 16)                                          [REQUIRED]
# =============================================================================
DB_USER=your_value_here
DB_PASSWORD=your_value_here          # openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
DATABASE_URL=your_value_here         # postgresql+asyncpg://USER:PASSWORD@postgres:5432/crypto_platform

POSTGRES_USER=your_value_here
POSTGRES_PASSWORD=your_value_here
POSTGRES_DB=crypto_platform


# =============================================================================
# REDIS                                                             [REQUIRED]
# =============================================================================
REDIS_PASSWORD=your_value_here       # openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
REDIS_URL=your_value_here            # redis://:PASSWORD@redis:6379/0


# =============================================================================
# JWT / AUTH                                                        [REQUIRED]
# =============================================================================
JWT_SECRET_KEY=your_value_here       # openssl rand -hex 64
JWT_SECRET=your_value_here           # same value as JWT_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


# =============================================================================
# APPLICATION URLS                                                  [REQUIRED]
# Set to your domain. Backend runs behind Nginx at /api, frontend at root.
# =============================================================================
FRONTEND_URL=your_value_here         # e.g. https://yourdomain.com
BACKEND_URL=your_value_here          # e.g. https://yourdomain.com/api
BACKEND_WS_URL=your_value_here       # e.g. wss://yourdomain.com/market/ws/prices


# =============================================================================
# FRONTEND (Next.js)                                                [REQUIRED]
# Injected at build time — must match BACKEND_URL / BACKEND_WS_URL above.
# =============================================================================
NEXT_PUBLIC_API_URL=your_value_here  # e.g. https://yourdomain.com/api
NEXT_PUBLIC_WS_URL=your_value_here   # e.g. wss://yourdomain.com/market/ws/prices


# =============================================================================
# ENVIRONMENT                                                       [REQUIRED]
# =============================================================================
ENVIRONMENT=production
DEBUG=false
AUTO_VERIFY_USERS=false


# =============================================================================
# EMAIL                                                             [OPTIONAL]
# Required for email verification flow. App works without it but verification
# emails will not be sent. Compatible with Resend, Gmail, SendGrid, etc.
# =============================================================================
SMTP_HOST=your_value_here            # e.g. smtp.resend.com
SMTP_PORT=587
SMTP_USER=your_value_here
SMTP_PASSWORD=your_value_here        # e.g. Resend API key (re_...)
SMTP_FROM=your_value_here            # e.g. noreply@yourdomain.com


# =============================================================================
# RATE LIMITING                                                     [OPTIONAL]
# =============================================================================
RATE_LIMIT_SIGNUP=5/hour
RATE_LIMIT_LOGIN=10/hour


# =============================================================================
# TIER STARTING BALANCES (in cents)                                [OPTIONAL]
# Free=$10k, Pro=$25k, Elite=$100k, Valkyrie=$500k
# =============================================================================
TIER_FREE_BALANCE=1000000
TIER_PRO_BALANCE=2500000
TIER_ELITE_BALANCE=10000000
TIER_VALKYRIE_BALANCE=50000000


# =============================================================================
# EXCHANGE API KEYS                                                 [OPTIONAL]
# App uses public WebSocket feeds without these. Keys unlock private endpoints.
# =============================================================================
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
COINGECKO_API_KEY=


# =============================================================================
# OPENROUTER AI                                                     [OPTIONAL]
# Powers AI trading analysis features.
# =============================================================================
OPENROUTER_API_KEY=


# =============================================================================
# STRIPE PAYMENTS                                                   [OPTIONAL]
# Required for paid tiers (Pro, Elite, Valkyrie).
# =============================================================================
STRIPE_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ELITE=
STRIPE_PRICE_ID_VALKYRIE=


# =============================================================================
# BACKUP ENCRYPTION                                                 [OPTIONAL]
# Used by scripts/backup.sh to encrypt .env backups with AES-256.
# =============================================================================
BACKUP_ENCRYPTION_KEY=
